# Ime projekta — uporablja se kot prefiks za Traefik routerje, service in middleware,
# ter kot ime docker interne mreže (${COMPOSE_PROJECT_NAME}-docker).
# Mora biti unikatno na serverju!
COMPOSE_PROJECT_NAME=mautic-instance1

# Domena, na kateri bo dostopen Mautic
DOMAIN=mautic.example.com

# Časovni pas
TIMEZONE=Europe/Ljubljana

# Verzija Mautic Docker slike (brez -apache sufiksa)
MAUTIC_VERSION=6.0.4

# --- MariaDB ---
MYSQL_DATABASE=mautic_db
MYSQL_USER=mautic_db_user
MYSQL_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# --- Hetzner Storage Box (samo če uporabljaš backup container) ---
# Najdeš v Hetzner Robot pod Storage Box > Credentials
STORAGE_BOX_USER=u123456
STORAGE_BOX_HOST=u123456.your-storagebox.de

# --- BorgBackup (samo če uporabljaš backup container) ---
# Naključno dolgo geslo za šifriranje backupov — shrani na varno mesto!
# Brez tega gesla backupov NE moreš obnoviti!
BORG_PASSPHRASE=change_me_very_long_random_passphrase
